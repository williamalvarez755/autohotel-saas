# ============================================================
# Configuración del sistema AutoHotel SaaS
# Copie este archivo como .env y ajuste los valores
# ============================================================

# Puerto del servidor web
PORT=3000

# Entorno: development | production
NODE_ENV=development

# ---- Base de datos MySQL / MariaDB ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=autohotel_saas

# TLS hacia MySQL administrado en la nube (Railway/Aiven/TiDB…)
# DB_SSL=1 activa la conexión cifrada; en local déjelo en 0.
DB_SSL=0
# CA del proveedor (opcional): contenido PEM con saltos de línea como \n
# DB_SSL_CA=

# ---- Sesiones ----
# Cadena aleatoria larga; cámbiela en producción
SESSION_SECRET=cambie-este-secreto-por-uno-aleatorio-largo

# Duración de la sesión en horas
SESSION_HORAS=12

# ---- Reglas de negocio (valores por defecto globales) ----
# Días de anticipación para marcar una suscripción como "por vencer"
DIAS_POR_VENCER=5
